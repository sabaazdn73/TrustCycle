# 1. IOTA Configuration
# IMPORTANT: Keep this mnemonic safe. If this is a mainnet key later, never share it!
IOTA_PRIVATE_KEY="your_iota_private_key_here"
ISSUER_MNEMONIC="your_12_word_mnemonic_here"
PACKAGE_ID="your_deployed_package_id_here"
PROTOCOL_CONFIG_ID="your_protocol_config_id_here"

# 2. Real-World Identity API (SerpApi)
SERP_API_KEY="your_serpapi_key_here"

# 3. Email Service (Resend)
RESEND_API_KEY="your_resend_api_key_here"
EMAIL_FROM="onboarding@resend.dev"

# 4. Administrative Keys
# This matches your admin check in the backend
ADMIN_ACCESS_KEY="your_admin_access_key_here"
# NEW: Must be exactly 32 characters for AES-256 Encryption!
ENCRYPTION_KEY="your_32_character_encryption_key_here"

# 5. Server Configuration
PORT=3001
NODE_ENV="development"

# 6. Database Connection (MongoDB Atlas)
MONGO_URI="your_mongodb_connection_string_here"